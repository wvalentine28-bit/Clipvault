# ──────────────────────────────────────────────
# ClipVault — only one key required
# ──────────────────────────────────────────────

# YouTube Data API Key (read-only, for fetching trending videos)
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create an API key → restrict to YouTube Data API v3
YOUTUBE_API_KEY=your_api_key_here

# Server port (optional, defaults to 3000)
PORT=3000
