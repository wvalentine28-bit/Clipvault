# ──────────────────────────────────────────────
# ClipVault Environment Configuration
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# YouTube Data API Key (for reading trending/viral videos)
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create API key → restrict to YouTube Data API v3
YOUTUBE_API_KEY=your_api_key_here

# OAuth 2.0 Credentials (for uploading to YOUR YouTube channel)
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID → Web Application
# 3. Add http://localhost:3000/auth/callback as Authorized Redirect URI
# 4. Enable YouTube Data API v3 in your project
YOUTUBE_CLIENT_ID=your_client_id_here
YOUTUBE_CLIENT_SECRET=your_client_secret_here
YOUTUBE_REDIRECT_URI=http://localhost:3000/auth/callback

# Server settings
PORT=3000
SESSION_SECRET=change-this-to-a-long-random-string
