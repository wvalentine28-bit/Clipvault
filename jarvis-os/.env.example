# ============================================================
# JARVIS OS - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ─── DATABASE ────────────────────────────────────────────────
DATABASE_URL="postgresql://jarvis:jarvispassword@localhost:5432/jarvisdb"
POSTGRES_USER=jarvis
POSTGRES_PASSWORD=jarvispassword
POSTGRES_DB=jarvisdb

# ─── REDIS ───────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=

# ─── AUTHENTICATION ──────────────────────────────────────────
NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars-here"
NEXTAUTH_URL="http://localhost:3000"
JWT_SECRET="your-jwt-secret-min-32-chars-here"
JWT_EXPIRES_IN="7d"

# OAuth Providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── AI PROVIDERS ────────────────────────────────────────────
# REQUIRED: Anthropic Claude (primary LLM for all chat and agents)
ANTHROPIC_API_KEY=sk-ant-...

# OPTIONAL: OpenAI — only needed if you want GPT models or Whisper API.
# Without this key, the system uses Claude for chat, local Whisper for
# transcription, and fastembed (local) for embeddings. Fully functional
# without it.
OPENAI_API_KEY=
OPENAI_ORG_ID=

# ─── VOICE ───────────────────────────────────────────────────
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
WHISPER_MODEL=base

# ─── WAKE WORD ───────────────────────────────────────────────
PICOVOICE_API_KEY=
WAKE_WORD_SENSITIVITY=0.5

# ─── VECTOR DATABASE ─────────────────────────────────────────
PINECONE_API_KEY=
PINECONE_ENVIRONMENT=
PINECONE_INDEX=jarvis-memory
# OR use Chroma (self-hosted)
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ─── SEARCH ──────────────────────────────────────────────────
SERPAPI_API_KEY=
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=

# ─── SMART HOME ──────────────────────────────────────────────
HOME_ASSISTANT_URL=http://localhost:8123
HOME_ASSISTANT_TOKEN=

# ─── GITHUB INTEGRATION ──────────────────────────────────────
GITHUB_TOKEN=
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=

# ─── EMAIL ───────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Gmail OAuth
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# ─── CALENDAR ────────────────────────────────────────────────
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=

# ─── APP CONFIGURATION ───────────────────────────────────────
NODE_ENV=development
API_PORT=3001
WEB_PORT=3000
AI_SERVICE_PORT=8080
API_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WS_URL=ws://localhost:3001
AI_SERVICE_URL=http://localhost:8080

# ─── SECURITY ────────────────────────────────────────────────
ENCRYPTION_KEY="your-32-byte-hex-encryption-key"
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# ─── LOGGING ─────────────────────────────────────────────────
LOG_LEVEL=info
SENTRY_DSN=

# ─── STORAGE ─────────────────────────────────────────────────
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
